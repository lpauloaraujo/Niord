<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F4F9"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Header / Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnVoltar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voltar"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FF000000" />

        <TextView
            android:id="@+id/headerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Contatos de Emergência"
            android:textColor="#FF000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnAction"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ação"
            android:src="@drawable/ic_add_button"
            app:tint="#FF000000"
            android:visibility="visible" />
    </RelativeLayout>

    <!-- Selection and Added contacts screens -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Add contacts screen -->
        <LinearLayout
            android:id="@+id/selectionScreenContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_caixa_texto"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <ImageButton
                    android:id="@+id/btnBuscarContatos"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Buscar"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_search"
                    app:tint="#FF666666" />

                <EditText
                    android:id="@+id/searchContatos"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="12dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Buscar por nome ou número"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLength="100"
                    android:singleLine="true"
                    android:textColor="#FF000000"
                    android:textColorHint="#FF999999"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnLimparBusca"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Limpar"
                    android:src="@drawable/ic_close"
                    app:tint="#FF666666"
                    android:visibility="gone"
                    android:scaleType="centerInside" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Seus Contatos"
                    android:textColor="#FF000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <LinearLayout
                        android:id="@+id/contatosList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#FFFFFF"
                        android:elevation="1dp" />
                </ScrollView>

                <TextView
                    android:id="@+id/emptyStateContatos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="24dp"
                    android:text="Nenhum contato disponível"
                    android:textColor="#FF999999"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Added contacts screen -->
        <LinearLayout
            android:id="@+id/selectedScreenContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Contatos Adicionados"
                android:textColor="#FF000000"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/contatosSelecionadosList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="1dp" />

            <TextView
                android:id="@+id/emptyStateSelecionados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="24dp"
                android:text="Nenhum contato adicionado\nToque no + para incluir contatos"
                android:textColor="#FF999999"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Permission Dialog View (hidden by default) -->
    <FrameLayout
        android:id="@+id/permissionDialogOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:elevation="10dp">

        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#FFFFFF"
            android:elevation="12dp"
            android:orientation="vertical"
            android:padding="28dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_phone"
                app:tint="#FF316DF6"
                android:contentDescription="Permissão" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Permitir acesso aos contatos?"
                android:textColor="#FF000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="É necessário permitir o acesso para escolher os contatos"
                android:textColor="#FF666666"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:spacing="8dp">

                <Button
                    android:id="@+id/btnNegarPermissao"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/selector_item_bg"
                    android:text="Não"
                    android:textColor="#FF316DF6"
                    android:textSize="14sp"
                    android:paddingHorizontal="24dp" />

                <Button
                    android:id="@+id/btnPermitirPermissao"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Permitir"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:paddingHorizontal="24dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>

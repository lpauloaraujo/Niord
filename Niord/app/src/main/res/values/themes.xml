<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Niord" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">#316DF6</item>
    </style>

    <style name="Theme.Niord.Splash" parent="Theme.Niord" />

    <style name="AccountFieldLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:textColor">#222222</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="AccountEditRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="AccountEditText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_caixa_texto</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textColorHint">#9E9E9E</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="AccountEditButton">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:contentDescription">Editar</item>
        <item name="android:padding">10dp</item>
        <item name="android:tint">#316DF6</item>
    </style>
</resources>
